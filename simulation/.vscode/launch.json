    "version": "0.2.0",
    "configurations": [

        {
            "name": "Get electricity market price from REE API",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/get_electricity_market_price.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["2022", "2024"]
        },
        {
            "name": "Run yearly simulation (static)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/yearly_simulation_static.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "/miniconda3/envs/conda-env/bin/python"
        },
        {
            "name": "Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "/miniconda3/envs/conda-env/bin/python"
        }
    ]
}