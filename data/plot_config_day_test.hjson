{
  title: "SOLhycool operation optimization",
  subtitle: "Experimental evaluation results",
  height: 3000,
  width: 1200,
  margin: {
    l:20,
    r:20,
    t:150,
    b:20,
    pad:5
  },
  vertical_spacing: 0.015,
  xdomain: [0, 0.9],
  // yaxis_right_pos
  xminor: true,
  xaxis_nticks: 24,
  hoverlabel_bgcolor: "rgba(255,255,255,0.8)", // Background color for hover labels
  title_delta_y: 0.001,

  vertical_highlights: {
    "var_id": "optim_eval",
  }

  # Individual plot attributes
  # First specify the plot attributes
  # In traces, specify the variables to be plotted, the definition order controls the order of the traces in the plot
  plots: {

    # Environment
    environment_: {
      title: "<b>Environment</b>",
      row_height: 0.5,
      // bg_color: "steelblue",
      ylabels_left: ["<b>Weather<br>conditions</b><br>ºC"],
      ylabels_right: ["<b>Relative<br>humidity</b> (%)"], # As many as n_yaxis-1
      ylims_left: 'manual',
      showlegend: true,
      legend_position: "top", // "top" (horizontal) or "side" (vertical)

      traces_left: [
        {
          var_id: "Tamb",
          name: "T<sub>amb</sub>", # "T<sub>amb,ts</sub>",
          mode: "lines",
          color: "plotly_green",
          showlegend: true,
          width: 3,
        },
      ],

      traces_right: [
        {
          var_id: "HR",
          name: "HR", # "T<sub>amb,ts</sub>",
          mode: "lines",
          color: "plotly_blue",
          width: 3,
          showlegend: true,
        },
      ]
    },

    load_conditions: {
      // title: "<b>Environment</b>",
      row_height: 1,
      // bg_color: "steelblue",
      ylabels_right: ["ºC"],
      ylabels_left: ["<b>Load<br>conditions</b><br>kW<sub>th</sub>"],
      ylims_right: 'manual',
      ylims_left: [0, 500],
      showlegend: true,
      legend_position: "top",

      traces_left: [
        {
          var_id: "Qc_absorbed",
          name: "Q̇<sub>c</sub>", # "T<sub>amb,ts</sub>",
          mode: "lines",
          color: "bg_gray",
          width: 3,
          fill: "tozeroy",
          showlegend: true,
        },
      ],
      traces_right: [
        {
          var_id: "Tv",
          name: "T<sub>v</sub>",
          mode: "markers+lines",
          color: "bg_gray",
          width: 3,
          showlegend: true,
        },
        {
          var_id: "Tc_in",
          name: "T<sub>c,in</sub>",
          mode: "markers+lines",
          color: "plotly_blue",
          dash: "dash",
          width: 3,
          showlegend: true,
        },
        {
          var_id: "Tc_out",
          name: "T<sub>c,out</sub>",
          mode: "markers+lines",
          color: "plotly_red",
          dash: "dot",
          width: 3,
          showlegend: true,
        },
      ],
    },

    costs_context: {
      // title: "<b>Environment</b>",
      row_height: 1,
      // bg_color: "steelblue",
      ylabels_left: ["<b>Resources<br>context</b><br>m<sup>3</sup>"],
      ylabels_right: ["€/kW<sub>e</sub>", "€/l"],
      // ylims_left: [0, 5000],
      ylims_left: 'manual_from_zero',
      ylims_right: ['manual', 'manual'],
      showlegend: true,
      legend_position: "top",
      "show_vertical_highlights": false, // Disable vertical highlights for this plot


      traces_left: [
        {
          var_id: "Vavail",
          name: "V<sub>avail</sub>",
          mode: "lines",
          color: "plotly_cyan",
          width: 3,
          fill: "tozeroy",
          showlegend: true,
        },
      ],
      traces_right: [
        [
          {
            var_id: "Pe",
            name: "P<sub>e</sub>", # "T<sub>amb,ts</sub>",
            mode: "lines",
            color: "plotly_yellow",
            width: 3,
            showlegend: true,
          },
        ],
        [
          {
            var_id: "Pw_s1",
            name: "P<sub>w,s1</sub>",
            mode: "lines",
            color: "turquesa",
            dash: "solid",
            width: 3,
            showlegend: true,
          },
          {
            var_id: "Pw_s2",
            name: "P<sub>w,s2</sub>",
            mode: "lines",
            color: "turquesa",
            dash: "dash",
            width: 3,
            showlegend: true,
          },
        ]
      ],
    },

