    },
  
    # Control plots

    temperatures_dc: {
      title: "<b>Regulatory control |</b> Dry cooler outlet temperature loop",
      row_height: 1,
      // bg_color: "bg_gray", # bg gray
      ylabels_left: ["<b>Controlled<br>variable</b><br>ºC"],
      ylims_left: 'manual',
      # ylabels_left: ["T<sub>dc</sub>"],
      showlegend: true,

      # Plotted between this plot and the next one
      show_active: false,
      active_var_id: "dc_active",
      active_color: "dc_green",
      tigth_vertical_spacing: true, # Reduce vertical spacing between this plot and the next one
      active_plot_domain_shift: 0.04, # Shift the active plot bottom domain to avoid overlap with the next plot

      traces_left: [
        {
          var_id: "Tdc_in",
          name: "T<sub>dc,in</sub>", # T<sub>dc,in,ts</sub>
          mode: "lines",
          color: "gray", # gray
          width: 2,
          showlegend: true,
          // "instrument": "pt100"
        },
        {
          var_id: "Tdc_out",
          name: "T<sub>dc,out</sub>", # "T<sub>dc,out</sub>",
          mode: "lines",
          color: "dc_green", # green DC
          showlegend: true,
          // "instrument": "pt100"
        },
        {
          var_id: "Tdc_out_sp",
          name: "T<sup>SP</sup><sub>dc,out</sub>", # "T<sub>dc,sp</sub>",
          mode: "lines",
          color: "dc_green", # green DC
          width: 4,
          dash: "dash", # "dot", "dash", "dashdot"
          showlegend: true,
        },
      ]
    },

    temperatures_dc_cv: {
      row_height: 0.7,
      // bg_color: "bg_gray", # bg gray
