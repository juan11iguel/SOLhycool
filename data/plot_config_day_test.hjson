            var_id: "Tdc_in",
            name: "T<sub>dc,in</sub>",
            mode: "markers+lines",
            color: "plotly_red",
            width: 3,
            showlegend: true,
          },
          {
            var_id: "Tdc_out",
            name: "T<sub>dc,out</sub>",
            mode: "markers+lines",
            color: "plotly_blue",
            width: 3,
