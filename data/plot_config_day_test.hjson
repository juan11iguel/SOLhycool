      // bg_color: "bg_gray", # bg gray
      # ylabels_left: ["T<sub>wct</sub>"],
      ylabels_left: ["<b>Controlled<br>variable</b><br>ºC"],
      ylims_left: 'manual',
      showlegend: true,
      
      # Plotted between this plot and the next one
      show_active: false,
      active_var_id: "wct_active",
      active_color: "wct_purple",
      active_plot_domain_shift: 0.04, # Shift the active plot bottom domain to avoid overlap with the next plot
      tigth_vertical_spacing: true, # Reduce vertical spacing between this plot and the next one

      traces_left: [
        {
