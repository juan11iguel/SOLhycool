    hydraulic_distribution: {
      row_height: 1,
      // bg_color: "bg_gray",
      title: "<b>Results</b>",
      ylabels_left: ["<b>Hydraulic<br>distribution</b><br>m<sup>3</sup>/h"],
      showlegend: true,
      legend_position: "top",
      traces_left: [],
      independent_xaxis: true,
      xminor: false, # To override the global xminor setting
    },

    "cooling_power_distribution": {
      "row_height": 1,
      # "bg_color": "bg_gray",
      "ylabels_left": ["<b>Cooling power<br>distribution</b><br>W<sub>th</sub>"],
      "showlegend": true,  
      "show_vertical_highlights": false, // Disable vertical highlights for this plot
