              "var_id": "Qdc",
              "name": "Q̇<sub>dc</sub>",
              "mode": "lines",
              "color": "dc_green",
              "width": 3,
              "fill": "tozeroy",
              "stackgroup": "cooling_power_distribution",
              "showlegend": true,
          },
          {
              "var_id": "Qwct",
              "name": "Q̇<sub>wct</sub>",
              "mode": "lines",
              "color": "wct_purple",
              "width": 3,
              "fill": "tonexty",
              "stackgroup": "cooling_power_distribution",
              "showlegend": true,
          },
        ],
      },
    
    wct: {
      title: "<b>Components</b>",
