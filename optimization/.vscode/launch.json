{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "cc horizon optimization - evaluate paretos",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cc_horizon_pareto_generation.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "/miniconda3/envs/conda-env/bin/python",
            "args": [
                "--values_per_decision_variable", "3",
                "--repeat_for_each_month"
            ]
        },
        {
            "name": "cc horizon optimization - complete",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cc_horizon_optimization.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "/miniconda3/envs/conda-env/bin/python",
            "args": [
                "--values_per_decision_variable", "2",
                "--date_span", "20220616", "20220616",
                "--evaluation_id", "debug",
                "--n_parallel_days", "1",
                "--n_parallel_steps", "1",
                "--power_threshold", "100", // To have less steps to evaluate
            ]
        },
        {
            "name": "cc horizon optimization - path finder",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cc_horizon_algo_comparison.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "/miniconda3/envs/conda-env/bin/python",
        }
    ]
}